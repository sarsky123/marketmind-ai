DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/appdb
REDIS_URL=redis://redis:6379/0

# OpenAI (required for real agent responses)
OPENAI_API_KEY=

# Tavily (optional; search_web degrades gracefully if unset)
TAVILY_API_KEY=

# Anonymous JWT auth (required)
AUTH_JWT_SECRET=change-me-in-production

# Base URL for scripts/generate_invite.py magic links (optional; defaults to localhost:5173)
# PUBLIC_APP_ORIGIN=http://localhost:5173

# Invite / visitor gates (API cost control)
MAX_DAILY_VISITORS=10
VISITOR_QUOTA=50
INVITE_QUOTA=200
# Redis EX on `invite:{token}` from `scripts/generate_invite.py` (default 7 days)
INVITE_TTL_SECONDS=604800
RATE_LIMIT_PER_MIN=20

# JWT cookie
JWT_EXPIRES_SECONDS=86400
JWT_ALGORITHM=HS256
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# CORS (comma-separated origins; credentials require explicit list)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# When true, use first X-Forwarded-For hop as client IP (trusted proxy)
CLIENT_IP_TRUST_PROXY=false

# Engine tuning (optional overrides)
# MAX_ORCHESTRATOR_ROUNDS=20
# MAX_FINANCE_ROUNDS=15
# MAX_CONTEXT_MESSAGES=60
# MAX_CONTEXT_MESSAGES=none

# Tool cache / Tavily
# YFINANCE_CACHE_TTL_SECONDS=300
# TAVILY_MAX_RESULTS=5

# Optional model overrides
# ORCHESTRATOR_MODEL=gpt-4o-mini
# FINANCE_MODEL=gpt-4o-mini
