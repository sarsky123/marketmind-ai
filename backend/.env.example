DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/appdb
REDIS_URL=redis://redis:6379/0

# OpenAI (required for real agent responses)
OPENAI_API_KEY=

# Tavily (optional; search_web degrades gracefully if unset)
TAVILY_API_KEY=

